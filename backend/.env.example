# ── Server
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000

# ── PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safeg_ai
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── Redis (caching + pub/sub)
REDIS_URL=redis://localhost:6379

# ── JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@syyaimsafeg.ai
SMTP_PASS=your_app_password
EMAIL_FROM="SafeG AI <alerts@syyaimsafeg.ai>"

# ── WhatsApp (Twilio / Meta Cloud API)
WHATSAPP_PROVIDER=twilio          # twilio | meta
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=+14155238886
META_WA_TOKEN=xxxx
META_WA_PHONE_ID=xxxx

# ── AI Engine
AI_ENGINE_URL=http://localhost:5001   # Python FastAPI AI service
AI_API_KEY=internal_ai_key

# ── File Storage (S3-compatible)
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=safeg-ai-evidence
S3_REGION=ap-south-1
S3_ACCESS_KEY=xxxx
S3_SECRET_KEY=xxxx

# ── Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Superadmin seed
ADMIN_EMAIL=admin@syyaimsafeg.ai
ADMIN_PASSWORD=Admin@SafeG2024!

# ── Razorpay Payment Gateway ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RZP_PLAN_STARTER_MONTHLY=plan_xxxx
RZP_PLAN_STARTER_ANNUAL=plan_xxxx
RZP_PLAN_GROWTH_MONTHLY=plan_xxxx
RZP_PLAN_GROWTH_ANNUAL=plan_xxxx
VITE_RAZORPAY_KEY=rzp_test_YOUR_KEY_ID
